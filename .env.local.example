# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_key
SUPABASE_SERVICE_ROLE_KEY=your_service_key

# Anthropic / Claude
ANTHROPIC_API_KEY=your_key

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
WHATSAPP_VERIFY_TOKEN=dealpulse_webhook_secret
WHATSAPP_APPOINTMENT_TEMPLATE_SID=HX...

# Meta Messenger / Instagram (optional)
MESSENGER_VERIFY_TOKEN=dealpulse_webhook_secret
INSTAGRAM_VERIFY_TOKEN=dealpulse_webhook_secret

# HubSpot
HUBSPOT_ACCESS_TOKEN=your_token
CLIENT_SECRET=your_client_secret

# Airia (required for hackathon)
AIRIA_API_KEY=your_key
AIRIA_AGENT_URL=https://api.airia.ai/v1/PipelineExecution/your_pipeline_id
AIRIA_PIPELINE_ID=your_pipeline_id

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Agent: set to "true" to send drafts directly without HITL approval
AGENT_SEND_DIRECTLY=false
